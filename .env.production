# Production-oriented defaults for the base docker-compose.yml stack.
# Override secrets and deployment-specific values in your orchestrator UI.

# Published images
ARGUS_BACKEND_IMAGE=ghcr.io/joelmale/argus-backend:main
ARGUS_SCANNER_IMAGE=ghcr.io/joelmale/argus-scanner:main
ARGUS_FRONTEND_IMAGE=ghcr.io/joelmale/argus-frontend:main

# Application
APP_ENV=production
APP_DEBUG=false
# APP_SECRET_KEY=change-me-to-a-long-random-string
ALLOWED_ORIGINS=["http://localhost:3000"]

# Publish bindings
# Keep Postgres and Redis loopback-only so they stay off the LAN.
# Backend and frontend stay host-reachable by default because a reverse proxy
# in another Docker stack cannot use the host loopback address unless the
# stacks share an external Docker network.
ARGUS_DB_BIND_HOST=127.0.0.1
ARGUS_DB_PORT=5432
ARGUS_REDIS_BIND_HOST=127.0.0.1
ARGUS_REDIS_PORT=6379
ARGUS_BACKEND_BIND_HOST=0.0.0.0
ARGUS_BACKEND_PORT=8000
ARGUS_FRONTEND_BIND_HOST=0.0.0.0
ARGUS_FRONTEND_PORT=3008

# Database
POSTGRES_DB=argus
POSTGRES_USER=argus
# POSTGRES_PASSWORD=change-me-db-password
# DATABASE_URL_DOCKER=postgresql+asyncpg://argus:change-me-db-password@db:5432/argus
# SCANNER_DATABASE_URL=postgresql+asyncpg://argus:change-me-db-password@127.0.0.1:5432/argus

# Redis
REDIS_URL_DOCKER=redis://redis:6379/0
# SCANNER_REDIS_URL=redis://127.0.0.1:6379/0

# Scanner
SCANNER_DEFAULT_TARGETS=192.168.1.0/24
SCANNER_INTERVAL_MINUTES=60
SCANNER_DEFAULT_PROFILE=balanced
SCANNER_PASSIVE_ARP=true

# SNMP
SNMP_COMMUNITY=public
SNMP_VERSION=2c
SNMP_TIMEOUT=5
SNMP_V3_USERNAME=
SNMP_V3_AUTH_KEY=
SNMP_V3_PRIV_KEY=
SNMP_V3_AUTH_PROTOCOL=sha
SNMP_V3_PRIV_PROTOCOL=aes

# Auth
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Notifications
NOTIFY_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# AI
AI_BACKEND=none
AI_ENABLE_PER_SCAN=true
AI_MAX_CONCURRENT_HOSTS=5
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=qwen2.5:7b
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Frontend
# INTERNAL_API_URL=http://backend:8000
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
