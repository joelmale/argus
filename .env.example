# ─── Application ──────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_DEBUG=true

# ─── Database ─────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=argus
POSTGRES_USER=argus
POSTGRES_PASSWORD=argus_dev_password
DATABASE_URL=postgresql+asyncpg://argus:argus_dev_password@db:5432/argus

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ─── Scanner ──────────────────────────────────────────────────
# Comma-separated CIDR ranges to scan by default
SCANNER_DEFAULT_TARGETS=192.168.1.0/24
SCANNER_INTERVAL_MINUTES=60
# Profile: polite | balanced | aggressive
SCANNER_DEFAULT_PROFILE=balanced
# Set to true to enable passive ARP listener (requires NET_RAW capability)
SCANNER_PASSIVE_ARP=true

# ─── AI Investigation Agent ───────────────────────────────────
# Backend: "ollama" (local GPU) | "anthropic" (API) | "none" (rule-based only)
AI_BACKEND=ollama
AI_ENABLE_PER_SCAN=true
# Max hosts the AI investigates simultaneously (tune for your GPU VRAM)
AI_MAX_CONCURRENT_HOSTS=5

# Ollama — points to your Ollama container
# Recommended models (tool-use capable): qwen2.5:7b, llama3.1:8b, qwen2.5:14b
OLLAMA_BASE_URL=http://ollama:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# Anthropic (optional fallback — leave blank to use Ollama only)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ─── SNMP ─────────────────────────────────────────────────────
SNMP_COMMUNITY=public
SNMP_VERSION=2c
SNMP_TIMEOUT=5

# ─── Auth ─────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
# First admin user (created on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ─── Notifications ────────────────────────────────────────────
# Webhook URL for new device / change alerts (optional)
NOTIFY_WEBHOOK_URL=
NOTIFY_EMAIL_SMTP_HOST=
NOTIFY_EMAIL_SMTP_PORT=587
NOTIFY_EMAIL_FROM=argus@homelab
NOTIFY_EMAIL_TO=
